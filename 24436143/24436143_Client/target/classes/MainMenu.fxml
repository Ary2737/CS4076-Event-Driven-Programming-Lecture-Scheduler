<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="border_pane" prefHeight="480.0" prefWidth="640.0" style="-fx-background-color: #f5f5f5;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.clientController.MainMenuController">

    <!-- TITLE -->
    <top>
        <Label fx:id="title_label" alignment="CENTER" style="-fx-font-family: Arial; -fx-font-weight: bold; -fx-font-size: 30;" text="UL Lecture Timetable" textFill="#30bc20" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="20.0" top="40.0" />
            </BorderPane.margin>
        </Label>
    </top>

    <!-- LOGO -->
    <center>
        <VBox alignment="CENTER">
            <children>
                <ImageView fitHeight="200.0" fitWidth="400.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@images/img.png" />
                    </image>
                </ImageView>
            </children>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER" spacing="40.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="50.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>
                <Button fx:id="add_button" mnemonicParsing="false" onAction="#handleModifyButtons" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #389421; -fx-background-radius: 5; -fx-font-weight: BOLD;" text="ADD Lecture" textFill="WHITE" />
                <Button fx:id="remove_button" mnemonicParsing="false" onAction="#handleModifyButtons" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #389421; -fx-background-radius: 5; -fx-font-weight: BOLD;" text="REMOVE Lecture" textFill="WHITE" />
                <Button fx:id="display_lectures_button" mnemonicParsing="false" onAction="#handleDisplayButtonClick" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: #389421; -fx-background-radius: 5; -fx-font-weight: BOLD;" text="DISPLAY Lectures" textFill="WHITE" />
            </children>
        </HBox>
    </bottom>
</BorderPane>
